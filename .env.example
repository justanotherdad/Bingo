# Copy to .env.local and fill from Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: Dashboard → Project Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: canonical URL for host “copy display link” buttons (e.g. https://bingo.yourdomain.com)
NEXT_PUBLIC_APP_URL=

# Optional: Vercel sets this automatically; used as fallback for absolute display URLs
# VERCEL_URL=
